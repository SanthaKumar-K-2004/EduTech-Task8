              "raw": "{\n  \"name\": \"Wireless Headphones\",\n  \"description\": \"Noise-cancelling Bluetooth headphones\",\n  \"price\": 149.99,\n  \"stock\": 25,\n  \"category\": \"Electronics\"\n}"
