              "raw": "http://localhost:5000/api/products/2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "products", "2"]
            },
            "description": "Partially update product - only specified fields are changed (PATCH)"
          },
          "response": []
        },
        {
          "name": "Update Non-existent Product (404)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
