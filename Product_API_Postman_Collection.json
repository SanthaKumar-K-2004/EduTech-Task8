              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Laptop\",\n  \"description\": \"Ultra-powerful laptop with RTX GPU\",\n  \"price\": 1299.99,\n  \"stock\": 8,\n  \"category\": \"Premium Electronics\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "products", "1"]
            },
            "description": "Update entire product (PUT replaces all fields)"
