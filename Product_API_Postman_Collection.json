          "name": "Get Non-existent Product (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/products/999",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "products", "999"]
            },
            "description": "Try to retrieve a product that doesn't exist (returns 404)"
          },
          "response": []
        }
