  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "health"]
        },
        "description": "Check if API is running"
      },
      "response": []
    },
    {
      "name": "Read Operations",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "products"]
            },
            "description": "Retrieve all products from the database"
          },
          "response": []
        },
        {
          "name": "Get All Products - Filter by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/products?category=Electronics",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "products"],
              "query": [
                {
                  "key": "category",
                  "value": "Electronics"
                }
              ]
            },
            "description": "Get products filtered by category"
          },
          "response": []
        },
        {
          "name": "Get All Products - Filter by Price Range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/products?minPrice=50&maxPrice=500",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "products"],
              "query": [
                {
                  "key": "minPrice",
                  "value": "50"
                },
                {
                  "key": "maxPrice",
                  "value": "500"
                }
              ]
            },
            "description": "Get products within a price range"
          },
          "response": []
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "products", "1"]
