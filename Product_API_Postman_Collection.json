            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ghost Product\",\n  \"price\": 99.99,\n  \"stock\": 0\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/products/999",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "products", "999"]
            },
            "description": "Try to update a product that doesn't exist (returns 404)"
          },
          "response": []
